---
---

<section id="location" class="bg-card-bg py-20 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">

      <!-- Left: Address Details -->
      <div>
        <p class="text-coral text-sm font-semibold uppercase tracking-widest mb-3">Find Us</p>
        <h2 class="text-3xl md:text-4xl font-bold text-charcoal font-nunito mb-8">
          In-Person Consultation
        </h2>

        <div class="flex flex-col gap-5">

          <!-- Address -->
          <div class="flex items-start gap-3">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="mt-0.5 flex-shrink-0">
              <path d="M12 2C8.13 2 5 5.13 5 9C5 14.25 12 22 12 22C12 22 19 14.25 19 9C19 5.13 15.87 2 12 2ZM12 11.5C10.62 11.5 9.5 10.38 9.5 9C9.5 7.62 10.62 6.5 12 6.5C13.38 6.5 14.5 7.62 14.5 9C14.5 10.38 13.38 11.5 12 11.5Z" fill="#E8856A"/>
            </svg>
            <p class="text-charcoal leading-relaxed">
              Paediatric Wellness by Dr. Shilpa,<br />
              Second Floor, ITPL Main Rd,<br />
              above Lenskart Store,<br />
              Basavanna Nagar, Hoodi,<br />
              Bengaluru, Karnataka 560048
            </p>
          </div>

          <!-- Clinic Hours -->
          <div class="flex items-start gap-3">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="mt-0.5 flex-shrink-0">
              <path d="M12 2C10.0222 2 8.08879 2.58649 6.4443 3.6853C4.79981 4.78412 3.51809 6.3459 2.76121 8.17317C2.00433 10.0004 1.8063 12.0111 2.19215 13.9509C2.578 15.8907 3.53041 17.6725 4.92894 19.0711C6.32746 20.4696 8.10929 21.422 10.0491 21.8079C11.9889 22.1937 13.9996 21.9957 15.8268 21.2388C17.6541 20.4819 19.2159 19.2002 20.3147 17.5557C21.4135 15.9112 22 13.9778 22 12C22 9.34784 20.9464 6.80429 19.0711 4.92893C17.1957 3.05357 14.6522 2 12 2ZM12 20C10.4178 20 8.87104 19.5308 7.55544 18.6518C6.23985 17.7727 5.21447 16.5233 4.60897 15.0615C4.00347 13.5997 3.84504 11.9911 4.15372 10.4393C4.4624 8.88743 5.22433 7.46197 6.34315 6.34315C7.46197 5.22433 8.88743 4.4624 10.4393 4.15372C11.9911 3.84504 13.5997 4.00346 15.0615 4.60896C16.5233 5.21447 17.7727 6.23984 18.6518 7.55544C19.5308 8.87103 20 10.4177 20 12C20 14.1217 19.1572 16.1566 17.6569 17.6569C16.1566 19.1571 14.1217 20 12 20ZM13 12V7C13 6.73478 12.8946 6.48043 12.7071 6.29289C12.5196 6.10536 12.2652 6 12 6C11.7348 6 11.4804 6.10536 11.2929 6.29289C11.1054 6.48043 11 6.73478 11 7V12.42C11.0001 12.6838 11.1044 12.9368 11.29 13.124L14.29 16.124C14.4783 16.3059 14.7311 16.4063 14.9933 16.404C15.2555 16.4017 15.5065 16.2969 15.6916 16.1118C15.8767 15.9267 15.9815 15.6757 15.9838 15.4135C15.9861 15.1513 15.8857 14.8985 15.704 14.71L13 12Z" fill="#E8856A"/>
            </svg>
            <div>
              <p class="text-charcoal font-medium">Mon – Sat</p>
              <p class="text-muted">5:00 PM – 6:30 PM</p>
            </div>
          </div>

        </div>

        <!-- Actions -->
        <div class="flex flex-wrap gap-3 mt-8">
          <a
            href="#contact"
            class="inline-flex items-center gap-1 px-5 py-2.5 rounded-full bg-coral text-white text-sm font-medium hover:bg-coral/90 transition-colors"
          >
            Book Consultation
          </a>
          <a
            href="https://maps.app.goo.gl/HUBpJb5QC9LXDe3W7"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1 px-5 py-2.5 rounded-full border border-coral text-coral text-sm font-medium hover:bg-coral/10 transition-colors"
          >
            Get Directions →
          </a>
        </div>
      </div>

      <!-- Right: Google Maps Embed -->
      <div class="rounded-2xl overflow-hidden shadow-md">
        <iframe
          src="https://maps.google.com/maps?q=Paediatric+Wellness+by+Dr.+Shilpa&t=&z=17&ie=UTF8&iwloc=&output=embed"
          width="100%"
          height="400"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Clinic location on Google Maps"
        ></iframe>
      </div>

    </div>
  </div>
</section>
