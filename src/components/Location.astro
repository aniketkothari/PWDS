---
---

<section id="location" class="bg-card-bg py-20 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">

      <!-- Left: Address Details -->
      <div>
        <p class="text-coral text-sm font-semibold uppercase tracking-widest mb-3">Find Us</p>
        <h2 class="text-3xl md:text-4xl font-bold text-charcoal font-nunito mb-8">
          In-Person Consultation
        </h2>

        <div class="flex items-start gap-3">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="mt-0.5 flex-shrink-0">
            <path d="M12 2C8.13 2 5 5.13 5 9C5 14.25 12 22 12 22C12 22 19 14.25 19 9C19 5.13 15.87 2 12 2ZM12 11.5C10.62 11.5 9.5 10.38 9.5 9C9.5 7.62 10.62 6.5 12 6.5C13.38 6.5 14.5 7.62 14.5 9C14.5 10.38 13.38 11.5 12 11.5Z" fill="#E8856A"/>
          </svg>
          <div>
            <p class="text-charcoal leading-relaxed">
              Paediatric Wellness by Dr. Shilpa, <br />
              Second Floor, ITPL Main Rd,<br />
              above Lenskart Store,<br />
              Basavanna Nagar, Hoodi,<br />
              Bengaluru, Karnataka 560048
            </p>
            <a
              href="https://maps.app.goo.gl/HUBpJb5QC9LXDe3W7"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 mt-4 px-4 py-2 rounded-full bg-coral text-white text-sm font-medium hover:bg-coral/90 transition-colors"
            >
              Get Directions →
            </a>
          </div>
        </div>
      </div>

      <!-- Right: Google Maps Embed -->
      <div class="rounded-2xl overflow-hidden shadow-md">
        <iframe
          src="https://maps.google.com/maps?q=Paediatric+Wellness+by+Dr.+Shilpa&t=&z=17&ie=UTF8&iwloc=&output=embed"
          width="100%"
          height="400"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Clinic location on Google Maps"
        ></iframe>
      </div>

    </div>
  </div>
</section>
