---
const testimonials = [
  {
    initials: 'R',
    avatarBg: '#FDE8D8',
    avatarText: '#E8856A',
    name: 'Riddhi',
    role: 'Mother',
    quote: 'Dr Shilpa is very friendly, approachable. My child had fever of 103. Dr Shilpa reassured me and treated my son without any unnecessary antibiotics. My kid just loves to go to her clinic.',
  },
  {
    initials: 'HA',
    avatarBg: '#DBEAFE',
    avatarText: '#3B82F6',
    name: 'Harmind Singh Arora',
    role: 'Father',
    quote: 'From the moment we met Dr. Shilpa Pandya, she put us at ease with her calm and reassuring demeanor. She took the time to listen to our daughter’s concerns and answered all of our questions in detail, making sure we understood everything. What impressed us the most about Dr. Shilpa was her caring and compassionate approach towards our daughter. She was patient and gentle with her, making sure she felt comfortable and at ease not just during her vaccinations but also when she was suffering with flu. She took the time to explain things in a way that our 2.5 year old daughter could understand, which helped to alleviate her fears and anxieties. Overall, we cannot recommend Dr. Shilpa Pandya highly enough. She is an outstanding pediatrician who goes above and beyond for her patients. If you are looking for a compassionate and caring pediatrician for your child, then look no further than Dr. Shilpa.',
  },
  {
    initials: 'AT',
    avatarBg: '#D1FAE5',
    avatarText: '#10B981',
    name: 'Ayesha Tanveer',
    role: 'Mother',
    quote: 'Visited doctor Shilpa for my baby, she diagnosed my baby problem and treated accordingly. She is very friendly and helpful. Will definitely recommend her for others.',
  },
];
---

<section id="testimonials" class="py-20 px-6 bg-white/50">
  <div class="max-w-6xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-14">
      <p class="text-[#E8856A] text-sm font-medium tracking-widest uppercase mb-3">From our patients' families</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-[#2D2A26]" style="font-family: 'Nunito', sans-serif;">
        What Parents Say
      </h2>
    </div>

    <!-- Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map((t) => (
        <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 flex flex-col gap-5 hover:shadow-md transition-shadow">
          <!-- Stars -->
          <div class="flex gap-1 text-[#E8856A]">
            {'★★★★★'.split('').map((star) => (
              <span>{star}</span>
            ))}
          </div>

          <!-- Quote -->
          <p class="text-[#7A7570] leading-relaxed flex-1">
            "{t.quote}"
          </p>

          <!-- Author -->
          <div class="flex items-center gap-3 pt-2 border-t border-gray-100">
            <div
              class="w-10 h-10 rounded-full flex items-center justify-center font-bold text-sm flex-shrink-0"
              style={`background-color: ${t.avatarBg}; color: ${t.avatarText};`}
            >
              {t.initials}
            </div>
            <div>
              <p class="font-semibold text-[#2D2A26] text-sm" style="font-family: 'Nunito', sans-serif;">{t.name}</p>
              <p class="text-[#7A7570] text-xs">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
