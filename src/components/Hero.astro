---
---

<section class="min-h-screen pt-24 pb-16 px-6 flex items-center">
  <div class="max-w-6xl mx-auto w-full grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

    <!-- Left Column -->
    <div class="flex flex-col gap-6">
      <!-- Eyebrow -->
      <p class="text-[#E8856A] text-sm font-medium italic tracking-wide">
        Your child's health, our priority
      </p>

      <!-- Heading -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight text-[#2D2A26]" style="font-family: 'Nunito', sans-serif;">
        Caring for Your<br />
        <span class="text-[#E8856A]">Little Ones,</span><br />
        with Heart.
      </h1>

      <!-- Description -->
      <p class="text-[#7A7570] text-lg leading-relaxed max-w-md">
        Compassionate, evidence-based paediatric care in a warm, welcoming environment. Because every child deserves to grow up healthy and happy.
      </p>

      <!-- Trust Badges -->
      <div class="flex flex-wrap gap-3 mt-2">
        <span class="inline-flex items-center gap-1.5 bg-white rounded-full px-4 py-2 text-sm font-medium text-[#2D2A26] shadow-sm border border-gray-100">
          ⭐ Top Rated
        </span>
        <span class="inline-flex items-center gap-1.5 bg-white rounded-full px-4 py-2 text-sm font-medium text-[#2D2A26] shadow-sm border border-gray-100">
          🛡️ Evidence-Based
        </span>
        <span class="inline-flex items-center gap-1.5 bg-white rounded-full px-4 py-2 text-sm font-medium text-[#2D2A26] shadow-sm border border-gray-100">
          ❤️ Child-Friendly
        </span>
        <span class="inline-flex items-center gap-1.5 bg-white rounded-full px-4 py-2 text-sm font-medium text-[#2D2A26] shadow-sm border border-gray-100">
          🏥 15+ Years
        </span>
      </div>

      <!-- CTA -->
      <div class="flex gap-4 mt-4">
        <a
          href="#contact"
          class="bg-[#E8856A] text-white rounded-full px-7 py-3 font-semibold hover:bg-[#E8856A]/90 transition-colors shadow-md"
        >
          Book Appointment
        </a>
        <a
          href="#services"
          class="border border-[#2D2A26]/20 text-[#2D2A26] rounded-full px-7 py-3 font-semibold hover:border-[#E8856A] hover:text-[#E8856A] transition-colors"
        >
          Our Services
        </a>
      </div>
    </div>

    <!-- Right Column — Image card with floating stats -->
    <div class="relative">
      <!-- Main image card -->
      <div class="rounded-3xl overflow-hidden shadow-lg bg-[#EEF7F4] aspect-[4/5] flex items-center justify-center relative">
        <!-- SVG Illustration -->
        <svg viewBox="0 0 400 500" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full p-8">
          <!-- Background shapes -->
          <circle cx="200" cy="200" r="160" fill="#D4EDE6" opacity="0.6"/>
          <circle cx="200" cy="200" r="120" fill="#C2E4DA" opacity="0.5"/>

          <!-- Doctor figure -->
          <!-- Body -->
          <rect x="145" y="230" width="110" height="130" rx="20" fill="#E8856A"/>
          <!-- White coat -->
          <rect x="148" y="233" width="104" height="127" rx="18" fill="white" opacity="0.9"/>
          <!-- Stethoscope -->
          <path d="M180 270 Q180 300 200 310 Q220 300 220 270" stroke="#E8856A" stroke-width="4" fill="none" stroke-linecap="round"/>
          <circle cx="200" cy="315" r="8" fill="#E8856A"/>
          <!-- Head -->
          <circle cx="200" cy="195" r="42" fill="#F5C5A3"/>
          <!-- Hair -->
          <path d="M158 185 Q160 155 200 150 Q240 155 242 185" fill="#6B4226"/>
          <!-- Eyes -->
          <circle cx="186" cy="195" r="5" fill="#2D2A26"/>
          <circle cx="214" cy="195" r="5" fill="#2D2A26"/>
          <!-- Smile -->
          <path d="M188 212 Q200 222 212 212" stroke="#2D2A26" stroke-width="2.5" fill="none" stroke-linecap="round"/>

          <!-- Child figure -->
          <!-- Body -->
          <rect x="265" y="300" width="80" height="90" rx="15" fill="#A8D8EA"/>
          <!-- Head -->
          <circle cx="305" cy="275" r="30" fill="#F5C5A3"/>
          <!-- Hair -->
          <path d="M275 267 Q278 248 305 245 Q332 248 335 267" fill="#8B5E3C"/>
          <!-- Eyes -->
          <circle cx="295" cy="276" r="4" fill="#2D2A26"/>
          <circle cx="315" cy="276" r="4" fill="#2D2A26"/>
          <!-- Smile -->
          <path d="M297 289 Q305 296 313 289" stroke="#2D2A26" stroke-width="2" fill="none" stroke-linecap="round"/>
          <!-- Arms waving up -->
          <path d="M265 320 Q245 295 235 280" stroke="#A8D8EA" stroke-width="14" stroke-linecap="round"/>
          <path d="M345 320 Q365 295 375 285" stroke="#A8D8EA" stroke-width="14" stroke-linecap="round"/>

          <!-- Hearts floating -->
          <path d="M110 130 C110 126 114 122 118 126 C122 122 126 126 126 130 C126 136 118 144 118 144 C118 144 110 136 110 130Z" fill="#E8856A" opacity="0.6"/>
          <path d="M290 100 C290 97 293 94 296 97 C299 94 302 97 302 100 C302 104 296 110 296 110 C296 110 290 104 290 100Z" fill="#E8856A" opacity="0.5"/>
          <path d="M330 160 C330 158 332 156 334 158 C336 156 338 158 338 160 C338 163 334 167 334 167 C334 167 330 163 330 160Z" fill="#E8856A" opacity="0.4"/>

          <!-- Stars -->
          <text x="90" y="200" font-size="20" opacity="0.4">✦</text>
          <text x="320" y="140" font-size="16" opacity="0.4">✦</text>
        </svg>
      </div>

      <!-- Floating card: Happy Families (top-right) -->
      <div class="absolute -top-4 -right-4 bg-white rounded-2xl shadow-lg px-4 py-3 flex items-center gap-3 min-w-[180px]">
        <div class="bg-[#EEF7F4] rounded-xl p-2">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M16 11C17.66 11 18.99 9.66 18.99 8C18.99 6.34 17.66 5 16 5C14.34 5 13 6.34 13 8C13 9.66 14.34 11 16 11ZM8 11C9.66 11 10.99 9.66 10.99 8C10.99 6.34 9.66 5 8 5C6.34 5 5 6.34 5 8C5 9.66 6.34 11 8 11ZM8 13C5.67 13 1 14.17 1 16.5V19H15V16.5C15 14.17 10.33 13 8 13ZM16 13C15.71 13 15.38 13.02 15.03 13.05C16.19 13.89 17 15.02 17 16.5V19H23V16.5C23 14.17 18.33 13 16 13Z" fill="#E8856A"/>
          </svg>
        </div>
        <div>
          <p class="font-bold text-[#2D2A26] text-sm" style="font-family: 'Nunito', sans-serif;">1000+</p>
          <p class="text-[#7A7570] text-xs">Happy Families</p>
        </div>
      </div>

      <!-- Floating card: Years Experience (bottom-left) -->
      <div class="absolute -bottom-4 -left-4 bg-white rounded-2xl shadow-lg px-4 py-3 flex items-center gap-3 min-w-[180px]">
        <div class="bg-[#FFF0EC] rounded-xl p-2">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 21.35L10.55 20.03C5.4 15.36 2 12.27 2 8.5C2 5.41 4.42 3 7.5 3C9.24 3 10.91 3.81 12 5.08C13.09 3.81 14.76 3 16.5 3C19.58 3 22 5.41 22 8.5C22 12.27 18.6 15.36 13.45 20.03L12 21.35Z" fill="#E8856A"/>
          </svg>
        </div>
        <div>
          <p class="font-bold text-[#2D2A26] text-sm" style="font-family: 'Nunito', sans-serif;">15+ Years</p>
          <p class="text-[#7A7570] text-xs">Experience</p>
        </div>
      </div>
    </div>

  </div>
</section>
