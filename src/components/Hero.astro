---
---

<section class="min-h-screen pt-24 pb-16 px-6 flex items-center">
  <div class="max-w-6xl mx-auto w-full grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

    <!-- Left Column -->
    <div class="flex flex-col gap-6">
      <!-- Eyebrow -->
      <p class="text-[#E8856A] text-sm font-medium italic tracking-wide">
        Your child's health, our priority
      </p>

      <!-- Heading -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight" style="font-family: 'Nunito', sans-serif;">
        <span class="text-[#6DC8DC]">Caring for Your</span><br />
        <span class="text-[#B8A0D0]">Little Ones,</span><br />
        <span class="text-[#F5A7BB]">with Heart.</span>
      </h1>

      <!-- Description -->
      <p class="text-[#706C82] text-lg leading-relaxed max-w-md">
        Compassionate, evidence-based paediatric care in a warm, welcoming environment. Because every child deserves to grow up healthy and happy.
      </p>

      <!-- Trust Badges -->
      <div class="flex flex-wrap gap-3 mt-2">
        <span class="inline-flex items-center gap-1.5 bg-white rounded-full px-4 py-2 text-sm font-medium text-[#2E2B3D] shadow-sm border border-gray-100">
          ⭐ Top Rated
        </span>
        <span class="inline-flex items-center gap-1.5 bg-white rounded-full px-4 py-2 text-sm font-medium text-[#2E2B3D] shadow-sm border border-gray-100">
          🛡️ Evidence-Based
        </span>
        <span class="inline-flex items-center gap-1.5 bg-white rounded-full px-4 py-2 text-sm font-medium text-[#2E2B3D] shadow-sm border border-gray-100">
          ❤️ Child-Friendly
        </span>
        <span class="inline-flex items-center gap-1.5 bg-white rounded-full px-4 py-2 text-sm font-medium text-[#2E2B3D] shadow-sm border border-gray-100">
          🏥 15+ Years
        </span>
      </div>

      <!-- CTA -->
      <div class="flex gap-4 mt-4">
        <a
          href="https://www.eka.care/doctor/shilpa-pandya-1771054459"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-[#E8856A] text-white rounded-full px-7 py-3 font-semibold hover:bg-[#E8856A]/90 transition-colors shadow-md"
        >
          Book Appointment
        </a>
        <a
          href="#services"
          class="border border-[#2E2B3D]/20 text-[#2E2B3D] rounded-full px-7 py-3 font-semibold hover:border-[#E8856A] hover:text-[#E8856A] transition-colors"
        >
          Our Services
        </a>
        <a
          href="#location"
          class="border border-[#2E2B3D]/20 text-[#2E2B3D] rounded-full px-7 py-3 font-semibold hover:border-[#E8856A] hover:text-[#E8856A] transition-colors"
        >
          Location
        </a>
      </div>
    </div>

    <!-- Right Column — Image card with floating stats -->
    <div class="relative">
      <!-- Main image card -->
      <div class="rounded-3xl overflow-hidden shadow-lg bg-white aspect-[4/5] relative">
        <img src="/images/PWDS_Web Logo.jpg" alt="Paediatric Wellness by Dr. Shilpa Pandya – Hoodi, Bengaluru" class="w-full h-full object-contain" fetchpriority="high" loading="eager" />
      </div>

      <!-- Floating card: Happy Families (top-right) -->
      <div class="absolute -top-4 -right-4 bg-white rounded-2xl shadow-lg px-4 py-3 flex items-center gap-3 min-w-[180px]">
        <div class="bg-[#EEF7F4] rounded-xl p-2">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M16 11C17.66 11 18.99 9.66 18.99 8C18.99 6.34 17.66 5 16 5C14.34 5 13 6.34 13 8C13 9.66 14.34 11 16 11ZM8 11C9.66 11 10.99 9.66 10.99 8C10.99 6.34 9.66 5 8 5C6.34 5 5 6.34 5 8C5 9.66 6.34 11 8 11ZM8 13C5.67 13 1 14.17 1 16.5V19H15V16.5C15 14.17 10.33 13 8 13ZM16 13C15.71 13 15.38 13.02 15.03 13.05C16.19 13.89 17 15.02 17 16.5V19H23V16.5C23 14.17 18.33 13 16 13Z" fill="#E8856A"/>
          </svg>
        </div>
        <div>
          <p class="font-bold text-[#2E2B3D] text-sm" style="font-family: 'Nunito', sans-serif;">1000+</p>
          <p class="text-[#706C82] text-xs">Happy Families</p>
        </div>
      </div>

      <!-- Floating card: Years Experience (bottom-left) -->
      <div class="absolute -bottom-4 -left-4 bg-white rounded-2xl shadow-lg px-4 py-3 flex items-center gap-3 min-w-[180px]">
        <div class="bg-[#FFF0EC] rounded-xl p-2">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 21.35L10.55 20.03C5.4 15.36 2 12.27 2 8.5C2 5.41 4.42 3 7.5 3C9.24 3 10.91 3.81 12 5.08C13.09 3.81 14.76 3 16.5 3C19.58 3 22 5.41 22 8.5C22 12.27 18.6 15.36 13.45 20.03L12 21.35Z" fill="#E8856A"/>
          </svg>
        </div>
        <div>
          <p class="font-bold text-[#2E2B3D] text-sm" style="font-family: 'Nunito', sans-serif;">15+ Years</p>
          <p class="text-[#706C82] text-xs">Experience</p>
        </div>
      </div>
    </div>

  </div>
</section>
