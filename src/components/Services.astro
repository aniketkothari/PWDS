---
const services = [
  {
    bg: '#DBEAFE',
    image: '/images/Paediatric-Treatment.avif',
    title: 'General Pediatrics and Neonatology',
    description: 'Comprehensive care for newborns, infants, and children — from routine check-ups to managing complex medical conditions at every stage of early life.',
  },
  {
    bg: '#D1FAE5',
    image: '/images/vaccination.avif',
    title: 'Vaccination and Well Baby Care',
    description: 'Complete immunisation schedules following national guidelines, alongside regular well-baby visits to monitor growth, development, and overall health.',
  },
  {
    bg: '#FFE4E1',
    image: '/images/childnutrition.avif',
    title: 'Nutrition, Growth and Development Assessment',
    description: 'Expert evaluation of your child\'s nutritional needs, growth milestones, and developmental progress to ensure they thrive at every age.',
  },
];
---

<section id="services" class="py-20 px-6">
  <div class="max-w-6xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-14">
      <p class="text-[#E8856A] text-sm font-medium tracking-widest uppercase mb-3">What we offer</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-[#2E2B3D]" style="font-family: 'Nunito', sans-serif;">
        Comprehensive Paediatric Care
      </h2>
    </div>

    <!-- Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {services.map((service) => (
        <div class="rounded-3xl bg-white shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow">
          <!-- Image Area -->
          <div
            class="h-48 flex items-center justify-center"
            style={`background-color: ${service.bg};`}
          >
            <div class="w-32 h-32 rounded-full overflow-hidden border-4 border-white shadow-md">
              <img
                src={service.image}
                alt={service.title}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
          </div>
          <!-- Content -->
          <div class="p-6">
            <h3 class="text-xl font-bold text-[#2E2B3D] mb-2" style="font-family: 'Nunito', sans-serif;">
              {service.title}
            </h3>
            <p class="text-[#706C82] leading-relaxed">
              {service.description}
            </p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
