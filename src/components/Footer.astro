            </svg>
            <span>
              Second Floor, ITPL Main Rd, above Lenskart Store, Basavanna Nagar, Hoodi, Bengaluru, Karnataka 560048
              <a
                href="https://maps.app.goo.gl/HUBpJb5QC9LXDe3W7"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1 mt-2 px-3 py-1 rounded-full bg-[#E8856A]/15 text-[#E8856A] text-xs font-medium hover:bg-[#E8856A]/25 transition-colors"
