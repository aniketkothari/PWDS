<footer id="contact" class="bg-[#2E2B3D] text-white py-16 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">

      <!-- Clinic Info -->
      <div>
        <div class="flex items-center gap-2 mb-4">
          <svg width="28" height="28" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="16" cy="16" r="16" fill="#E8856A" fill-opacity="0.2"/>
            <path d="M16 8C16 8 10 12 10 17C10 20.3 12.7 23 16 23C19.3 23 22 20.3 22 17C22 12 16 8 16 8Z" fill="#E8856A"/>
            <path d="M13 18H19M16 15V21" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span class="font-bold text-lg" style="font-family: 'Nunito', sans-serif;">Paediatric Wellness</span>
        </div>
        <p class="text-white/60 leading-relaxed text-sm">
          by Dr. Shilpa<br />
          Compassionate care for your little ones, every step of the way.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-bold mb-4 text-white/90" style="font-family: 'Nunito', sans-serif;">Quick Links</h4>
        <ul class="space-y-2">
          <li><a href="#about" class="text-white/60 hover:text-[#E8856A] transition-colors text-sm">About</a></li>
          <li><a href="#services" class="text-white/60 hover:text-[#E8856A] transition-colors text-sm">Services</a></li>
          <li><a href="#testimonials" class="text-white/60 hover:text-[#E8856A] transition-colors text-sm">Testimonials</a></li>
          <li><a href="#contact" class="text-white/60 hover:text-[#E8856A] transition-colors text-sm">Contact</a></li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h4 class="font-bold mb-4 text-white/90" style="font-family: 'Nunito', sans-serif;">Contact Us</h4>
        <ul class="space-y-3 text-sm text-white/60">
          <li class="flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M6.62 10.79C8.06 13.62 10.38 15.93 13.21 17.38L15.41 15.18C15.68 14.91 16.08 14.82 16.43 14.94C17.55 15.31 18.76 15.51 20 15.51C20.55 15.51 21 15.96 21 16.51V20C21 20.55 20.55 21 20 21C10.61 21 3 13.39 3 4C3 3.45 3.45 3 4 3H7.5C8.05 3 8.5 3.45 8.5 4C8.5 5.25 8.7 6.45 9.07 7.57C9.18 7.92 9.1 8.31 8.82 8.59L6.62 10.79Z" fill="#E8856A"/>
            </svg>
            +91 81238 36464
          </li>
          <li class="flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M20 4H4C2.9 4 2 4.9 2 6V18C2 19.1 2.9 20 4 20H20C21.1 20 22 19.1 22 18V6C22 4.9 21.1 4 20 4ZM20 8L12 13L4 8V6L12 11L20 6V8Z" fill="#E8856A"/>
            </svg>
            drshilpapandya@gmail.com
          </li>
          <li class="flex items-start gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="mt-0.5 flex-shrink-0">
